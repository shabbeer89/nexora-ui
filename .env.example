# ============================================
# NEXORA UI - Environment Configuration
# ============================================
# Last Updated: 2026-02-27
# Environment: Development (Local)
# Architecture: Unified Control Plane
# ============================================

# --------------------------------------------
# PRIMARY API ENDPOINT
# --------------------------------------------

# Nexora Bot API (Unified Control Plane)
# Browser-facing: use relative path '' so Next.js proxy handles routing
# Server-side: NEXORA_BACKEND_URL points directly to the droplet (not exposed to browser)
NEXT_PUBLIC_NEXORA_API_URL=
NEXORA_BACKEND_URL=http://64.227.151.249:8888
HUMMINGBOT_API_URL=http://64.227.151.249:8888
NEXORA_API_URL=http://64.227.151.249:8888
HUMMINGBOT_API_USER=admin
HUMMINGBOT_API_PASS=admin

# --------------------------------------------
# REAL-TIME COMMUNICATION
# --------------------------------------------

# WebSocket Connection
# For real-time bot status and trading updates via Nexora Bot
# Note: WebSocket proxying requires a custom WS proxy or use the droplet URL directly
NEXT_PUBLIC_WS_URL=ws://64.227.151.249:8888/ws

# MQTT Broker (EMQX)
# For internal service communication and logging
NEXT_PUBLIC_MQTT_URL=ws://localhost:8083/mqtt

# --------------------------------------------
# REMOTE DEPLOYMENT (DigitalOcean Droplet)
# --------------------------------------------
# Uncomment and update these when connecting to remote droplet

# Remote Droplet IP: 64.227.151.249
NEXT_PUBLIC_NEXORA_API_URL=https://livecam-reverse-odds-deals.trycloudflare.com
NEXT_PUBLIC_WS_URL=wss://livecam-reverse-odds-deals.trycloudflare.com/ws
NEXT_PUBLIC_MQTT_URL=wss://livecam-reverse-odds-deals.trycloudflare.com/mqtt

# --------------------------------------------
# DEVELOPMENT SETTINGS
# --------------------------------------------

# Node Environment
NODE_ENV=development

# Enable detailed error messages in development
NEXT_PUBLIC_SHOW_ERROR_DETAILS=true

# Polling Interval (milliseconds)
# UI polls Nexora Bot API every 5 seconds for updates
NEXT_PUBLIC_POLLING_INTERVAL=5000

# --------------------------------------------
# OPTIONAL: EXTERNAL SERVICES
# --------------------------------------------

# Analytics (if using)
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry Error Tracking (if using)
# NEXT_PUBLIC_SENTRY_DSN=

# --------------------------------------------
# ARCHITECTURE NOTES
# --------------------------------------------
# The Nexora UI follows a clean architecture pattern:
# 
# Nexora UI (Port 3000)
#     ↓ (HTTP/WS)
# Nexora Bot API (Port 8888) - UNIFIED CONTROL PLANE
#     ↓ (Internal)
#     ├── Hummingbot API (Port 8000) - CEX Trading
#     ├── FreqTrade API (Port 8080) - Strategy & ML
#     └── Gateway API (Port 15888) - DEX Trading
#
# Benefits:
# - Single point of communication
# - Centralized authentication & rate limiting
# - Simplified error handling
# - Easier to maintain and scale
# ============================================
