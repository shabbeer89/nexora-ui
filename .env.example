# ============================================
# NEXORA UI - Environment Configuration Template
# ============================================
# Copy this file to .env.local and update values
# Architecture: Unified Control Plane
# ============================================

# --------------------------------------------
# PRIMARY API ENDPOINT
# --------------------------------------------

# Nexora Bot API (Unified Control Plane)
# ALL communication goes through this single endpoint
NEXT_PUBLIC_NEXORA_API_URL=http://localhost:8888

# --------------------------------------------
# REAL-TIME COMMUNICATION
# --------------------------------------------

# WebSocket Connection
NEXT_PUBLIC_WS_URL=ws://localhost:8888/ws

# MQTT Broker (EMQX)
NEXT_PUBLIC_MQTT_URL=ws://localhost:8083/mqtt

# --------------------------------------------
# DEVELOPMENT SETTINGS
# --------------------------------------------

NODE_ENV=development
NEXT_PUBLIC_SHOW_ERROR_DETAILS=true
NEXT_PUBLIC_POLLING_INTERVAL=5000

# --------------------------------------------
# REMOTE DEPLOYMENT (Optional)
# --------------------------------------------
# Uncomment when connecting to remote droplet
# NEXT_PUBLIC_NEXORA_API_URL=https://your-tunnel-url.trycloudflare.com
# NEXT_PUBLIC_WS_URL=wss://your-tunnel-url.trycloudflare.com/ws
# NEXT_PUBLIC_MQTT_URL=wss://your-tunnel-url.trycloudflare.com/mqtt

# --------------------------------------------
# ARCHITECTURE
# --------------------------------------------
# Nexora UI → Nexora Bot API (Port 8888)
#                ├── Hummingbot (CEX)
#                ├── FreqTrade (Strategy/ML)
#                └── Gateway (DEX)

